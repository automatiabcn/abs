/_agent-tasks/
/LESSONS.md
# Local dev/audit output and CI sbom output. Ignore everything under
# artifacts/ EXCEPT the two paths the test suite treats as functional
# fixtures: promise_verify/ (eval contract gated by test_promise_v6) and
# sprint_q3/repro.sh (fs-scan allowlist contract).
/artifacts/*
!/artifacts/promise_verify/
!/artifacts/sprint_q3/
/artifacts/sprint_q3/*
!/artifacts/sprint_q3/repro.sh
# Stale committed benchmark outputs — regenerated by benchmarks.yml / k6-weekly.
/benchmarks/results/
# Vendor-side ops tooling (release / licensing) — kept out of the repo.
/scripts/release.sh
/scripts/mint_and_email.sh
/scripts/customer_onboard.sh
/scripts/_mint_license.py

# Local-only dev run artifacts (savepoint exclusions — never committed)
.localrun/
**/.localrun/
core/landing/.localrun_frontend.sh
core/landing/.localrun_*.mjs
*.bak
.env.bak.*
infra/*.bak
